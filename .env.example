# MySQL
MYSQL_ROOT_PASSWORD=pixelmart_root
MYSQL_DATABASE=pixelmart
MYSQL_USER=pixelmart
MYSQL_PASSWORD=pixelmart

# JWT (auth-service) — change in production
JWT_SECRET=change-me-to-a-long-random-secret-at-least-256-bits
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Storage (catalog-service)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/uploads

# SMTP (notification-service — set in .env, never commit real passwords)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
